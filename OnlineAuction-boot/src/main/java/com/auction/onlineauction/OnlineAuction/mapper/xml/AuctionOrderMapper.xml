<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.auction.onlineauction.OnlineAuction.mapper.AuctionOrderMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.auction.onlineauction.OnlineAuction.entity.AuctionOrder">
        <id column="id" property="id" />
        <result column="order_no" property="orderNo" />
        <result column="goods_id" property="goodsId" />
        <result column="buyer_id" property="buyerId" />
        <result column="seller_id" property="sellerId" />
        <result column="record_id" property="recordId" />
        <result column="deal_price" property="dealPrice" />
        <result column="deposit_amount" property="depositAmount" />
        <result column="remain_amount" property="remainAmount" />
        <result column="pay_deadline" property="payDeadline" />
        <result column="order_status" property="orderStatus" />
        <result column="create_time" property="createTime" />
        <result column="update_time" property="updateTime" />
        <result column="del_flag" property="delFlag" />
    </resultMap>

    <select id="selectOrdersPendingCommissionSettlement" resultMap="BaseResultMap">
        SELECT o.* FROM auction_order o
        WHERE o.del_flag = 0 AND o.order_status = 3
        AND NOT EXISTS (
            SELECT 1 FROM auction_fee_record f
            WHERE f.order_id = o.id AND f.fee_type = 1 AND f.del_flag = 0
        )
        ORDER BY o.create_time DESC
    </select>

</mapper>
