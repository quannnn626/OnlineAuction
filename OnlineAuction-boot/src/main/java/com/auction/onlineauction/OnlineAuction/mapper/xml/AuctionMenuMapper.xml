<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.auction.onlineauction.OnlineAuction.mapper.AuctionMenuMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.auction.onlineauction.OnlineAuction.entity.AuctionMenu">
        <id column="id" property="id" />
        <result column="menu_name" property="menuName" />
        <result column="parent_id" property="parentId" />
        <result column="menu_path" property="menuPath" />
        <result column="menu_icon" property="menuIcon" />
        <result column="menu_type" property="menuType" />
        <result column="permission_code" property="permissionCode" />
        <result column="menu_sort" property="menuSort" />
        <result column="menu_status" property="menuStatus" />
        <result column="remark" property="remark" />
        <result column="create_time" property="createTime" />
        <result column="update_time" property="updateTime" />
        <result column="del_flag" property="delFlag" />
    </resultMap>

    <!-- 根据角色类型查询菜单列表 -->
    <select id="selectMenusByRoleType" resultMap="BaseResultMap">
        SELECT DISTINCT m.*
        FROM auction_menu m
        INNER JOIN auction_permission p ON m.permission_code = p.permission_code
        INNER JOIN auction_role_permission rp ON p.id = rp.permission_id
        WHERE rp.role_type = #{roleType}
          AND m.menu_type = 1
          AND m.menu_status = 1
          AND m.del_flag = 0
          AND p.permission_status = 1
        ORDER BY m.menu_sort ASC, m.id ASC
    </select>

    <!-- 查询所有菜单列表（不区分角色权限） -->
    <select id="selectAllMenus" resultMap="BaseResultMap">
        SELECT m.*
        FROM auction_menu m
        WHERE m.menu_type = 1
          AND m.menu_status = 1
          AND m.del_flag = 0
        ORDER BY m.menu_sort ASC, m.id ASC
    </select>

</mapper>

