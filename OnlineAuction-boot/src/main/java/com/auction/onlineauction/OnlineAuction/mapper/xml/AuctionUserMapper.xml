<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.auction.onlineauction.OnlineAuction.mapper.AuctionUserMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.auction.onlineauction.OnlineAuction.entity.AuctionUser">
        <id column="id" property="id" />
        <result column="user_name" property="userName" />
        <result column="password" property="password" />
        <result column="real_name" property="realName" />
        <result column="nick_name" property="nickName" />
        <result column="phone" property="phone" />
        <result column="email" property="email" />
        <result column="avatar" property="avatar" />
        <result column="sex" property="sex" />
        <result column="user_role" property="userRole" />
        <result column="seller_audit_status" property="sellerAuditStatus" />
        <result column="seller_audit_remark" property="sellerAuditRemark" />
        <result column="user_status" property="userStatus" />
    <result column="risk_level" property="riskLevel" />
        <result column="login_ip" property="loginIp" />
        <result column="login_date" property="loginDate" />
        <result column="create_time" property="createTime" />
        <result column="update_time" property="updateTime" />
        <result column="del_flag" property="delFlag" />
    </resultMap>

    <!-- 风控：有风险行为的用户（曾触发风控出价规则 或 已标记风险等级） -->
    <select id="selectUsersWithRiskActivityForRisk" resultType="java.util.HashMap">
        SELECT u.id AS userId,
               u.user_name AS userName,
               u.nick_name AS nickName,
               u.risk_level AS riskLevel,
               COALESCE(rc.cnt, 0) AS riskBidCount
        FROM auction_user u
        LEFT JOIN (
            SELECT buyer_id, COUNT(*) AS cnt
            FROM auction_record
            WHERE del_flag = 0 AND risk_rule_type &gt; 0
            GROUP BY buyer_id
        ) rc ON rc.buyer_id = u.id
        WHERE u.del_flag = 0
          AND (COALESCE(u.risk_level, 0) &gt; 0 OR COALESCE(rc.cnt, 0) &gt; 0)
        ORDER BY COALESCE(rc.cnt, 0) DESC, u.id DESC
    </select>

</mapper>
