<view class="page login-page">
  <view class="card">
    <view class="title">微信登录</view>
    <view class="hint">请输入手机号，首次登录将自动注册</view>
    <input class="input" placeholder="手机号（11位）" type="number" maxlength="11" bindinput="onInputPhone" />
    <button class="btn-primary submit" loading="{{loading}}" bindtap="onSubmit">登录</button>
  </view>
</view>
