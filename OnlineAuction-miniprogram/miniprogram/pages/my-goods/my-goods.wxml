<view class="page">
  <view class="card">
    <view class="title">我的商品</view>
  </view>

  <view class="card" wx:for="{{list}}" wx:key="id">
    <view class="goods-name">{{item.goodsName}}</view>
    <view class="goods-desc">{{item.goodsDesc || '暂无描述'}}</view>
    <view class="goods-price">当前价：{{item.currentHighestPrice || item.basePrice || 0}}</view>
  </view>

  <view wx:if="{{list.length === 0}}" class="empty">暂无我的商品</view>
</view>
