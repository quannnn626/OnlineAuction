<view class="page">
  <view class="card">
    <view class="title">设置登录密码</view>
    <input class="input" placeholder="请输入新密码（至少6位）" type="password" bindinput="onInputPassword" />
    <input class="input" placeholder="确认新密码" type="password" bindinput="onInputConfirmPassword" />
    <button class="btn-primary submit" loading="{{loading}}" bindtap="onSubmit">提交</button>
  </view>
</view>

