<view class="page">
  <view class="card">
    <view class="title">设置昵称与登录密码</view>
    <view class="hint">需同时填写，完成后可使用网页端登录</view>
    <input class="input" placeholder="昵称（2～50字，勿用「微信用户」）" bindinput="onInputNickName" />
    <input class="input" placeholder="登录密码（至少6位）" type="password" bindinput="onInputPassword" />
    <input class="input" placeholder="确认密码" type="password" bindinput="onInputConfirmPassword" />
    <button class="btn-primary submit" loading="{{loading}}" bindtap="onSubmit">提交</button>
  </view>
</view>
